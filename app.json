{
  "expo": {
    "name": "3i Learning",
    "slug": "3i-learning",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "threeilearning",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "android": {
      "package": "com.learning3i.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.learning3i.app",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "3i Learning",
      "shortName": "3i Learning",
      "description": "Comprehensive math education platform with courses, tests, daily missions, and AI tutoring by Pankaj Sir",
      "backgroundColor": "#0A1628",
      "themeColor": "#1A56DB"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "http://localhost:5000"
        }
      ],
      "expo-notifications",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "3i-learning-app",
          "organization": "3i-learning"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "http://localhost:5000"
      },
      "eas": {
        "projectId": "1a053771-7e15-4507-9ecb-18c317018357"
      }
    },
    "owner": "pankaj_nagar"
  }
}
