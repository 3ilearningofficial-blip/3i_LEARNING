# Copy to .env for local development. On Vercel, add the EXPO_PUBLIC_* vars under
# Project → Settings → Environment Variables (enable Production AND Preview), then redeploy.

# --- Required for web app (Expo public — embedded in browser bundle at build time) ---
EXPO_PUBLIC_API_BASE_URL=https://api.3ilearning.in
EXPO_PUBLIC_DOMAIN=localhost:5000
EXPO_PUBLIC_TLDRAW_LICENSE_KEY=
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=i3-learning

# --- Backend only (EC2 / local server — NOT exposed to browser) ---
NODE_ENV=development
PORT=5000
DATABASE_URL=
SESSION_SECRET=
DOMAIN=localhost:5000

# Neon / Postgres pool (production EC2 — tune via PM2 .env)
# PG_POOL_MAX=15
# PG_POOL_MIN=0
# PG_LISTEN_POOL_MAX=8
# NEON_KEEPALIVE=false   # default off; set true only if EC2 and Neon are in different regions

# --- Neon scale-to-zero tuning ---
# Neon only suspends compute after ~5 min with zero queries. Keep every recurring
# background DB pinger spaced >5 min apart so idle periods (nights) cost nothing.
# Adaptive scheduler sleep cap (ms) when no jobs are due — default 900000 (15 min).
# (The tick still wakes exactly on the next scheduled_jobs.run_at, so reminders
# stay precise; this cap only applies when nothing is scheduled.)
# SCHEDULER_MAX_SLEEP_MS=900000
# Cloudflare recording archive sweep interval (ms) — default 900000 (15 min).
# CF_ARCHIVE_SWEEP_MS=900000

# OTP token signing secret (required; hard-fail at backend startup if missing)
OTP_HMAC_SECRET=

# Web Push (VAPID) — required for browser push notifications.
# Generate once with: npx web-push generate-vapid-keys
# Without these, /api/push/web-public-key returns empty and web push is disabled.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@3ilearning.com

# Redis (Upstash or compatible — optional shared live-class notification dedup)
# Use the rediss:// URL from your provider; REST URL/token are optional (not used by the Node server).
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate-limit counters default to PostgreSQL so auth/login keeps working if Redis quota is exhausted.
# Set any of these to redis only after provisioning enough Redis quota. Values: pg, redis, memory.
# NOTE: GLOBAL_RATE_LIMIT_STORE defaults to `memory` — the global /api guard would
# otherwise write a PG upsert on every request, keeping Neon compute busy 24/7.
# In-memory is per-worker, which is fine for a coarse "slow down" guard.
RATE_LIMIT_STORE=pg
AUTH_RATE_LIMIT_STORE=pg
MEDIA_RATE_LIMIT_STORE=pg
GLOBAL_RATE_LIMIT_STORE=memory

# LiveKit (classroom video)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# tldraw (optional on server; web uses EXPO_PUBLIC_TLDRAW_LICENSE_KEY)
TLDRAW_LICENSE_KEY=

# Cloudflare R2 / Stream, Razorpay, Firebase, etc.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
CF_STREAM_ACCOUNT_ID=
CF_STREAM_API_TOKEN=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
FIREBASE_SERVICE_ACCOUNT_JSON=
GEMINI_API_KEY=
OPENAI_API_KEY=
