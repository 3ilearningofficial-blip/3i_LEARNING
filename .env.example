NODE_ENV=production
PORT=5000

# Public app/backend host used by the Expo app on native builds.
# Example: EXPO_PUBLIC_DOMAIN=api.3ilearning.in
EXPO_PUBLIC_DOMAIN=

# Absolute API base URL used by download-related features.
# Example: EXPO_PUBLIC_API_URL=https://api.3ilearning.in
EXPO_PUBLIC_API_URL=

# Database
DATABASE_URL=
SESSION_SECRET=

# Firebase client
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase admin/server
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMS OTP provider
FAST2SMS_API_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Cloudflare Stream
CF_STREAM_ACCOUNT_ID=
CF_STREAM_API_TOKEN=

# Optional native playback helper
EXPO_PUBLIC_CLOUDFLARE_ACCOUNT_ID=
