{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "expo:dev": "npx expo start --localhost",
    "server:dev": "npx tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "start": "npx expo start",
    "test": "node --env-file=.env node_modules/vitest/vitest.mjs --run",
    "test:db": "cross-env RUN_DB_TESTS=true node --env-file=.env node_modules/vitest/vitest.mjs --run",
    "test:watch": "vitest",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "quality": "npm run lint && npx tsc --noEmit && npm run test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/s3-request-presigner": "^3.1028.0",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.83.0",
    "@types/compression": "^1.8.1",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "drizzle-orm": "^0.39.3",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.11",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "^55.0.8",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-router": "~6.0.17",
    "expo-screen-capture": "~8.0.9",
    "expo-screen-orientation": "~9.0.8",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.19.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^10.3.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "razorpay": "^2.9.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-crypto-js": "^1.0.0",
    "react-native-flag-secure": "^1.0.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.20.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.5.1",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.10",
    "@vitest/ui": "^4.1.4",
    "drizzle-kit": "^0.18.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "fast-check": "^4.6.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  },
  "private": true
}
