{
  "extends": "./tsconfig.expo-base.json",
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-native",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "module": "preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "customConditions": [
      "react-native"
    ],
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "tldraw": [
        "./node_modules/tldraw/dist-esm/index.d.mts"
      ],
      "@tldraw/tldraw": [
        "./node_modules/@tldraw/tldraw/dist-esm/index.d.mts"
      ],
      "@tldraw/sync": [
        "./node_modules/@tldraw/sync/dist-esm/index.d.mts"
      ],
      "react-native": [
        "./node_modules/react-native/types/index.d.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "android",
    "ios"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
